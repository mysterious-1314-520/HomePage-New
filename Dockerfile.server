FROM node:18-alpine

LABEL maintainer="计堡"
LABEL description="HomePage - 前台服务"

WORKDIR /app

COPY server/package.json ./server/

RUN cd server && npm install --production && cd ..

COPY . .

RUN mkdir -p data static/uploads

EXPOSE 4000

ENV NODE_ENV=production
ENV PORT=4000

CMD ["node", "server/index.js"]
