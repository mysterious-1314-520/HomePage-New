{
  "name": "homepage",
  "version": "1.0.0",
  "description": "计堡个人主页 - 功能完整的个人主页系统",
  "main": "index.js",
  "scripts": {
    "start": "bash start.sh",
    "dev": "bash start.sh",
    "server": "cd server && npm start",
    "admin": "cd admin && npm start",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "lint": "npx eslint server/*.js server/routes/*.js admin/*.js",
    "lint:fix": "npx eslint server/*.js server/routes/*.js admin/*.js --fix",
    "format": "npx prettier --write \"server/**/*.js\" \"admin/**/*.js\"",
    "format:check": "npx prettier --check \"server/**/*.js\" \"admin/**/*.js\""
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.3.0"
  },
  "keywords": [
    "homepage",
    "personal-website",
    "portfolio",
    "fastify",
    "sqlite"
  ],
  "author": "计堡",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mysterious-1314-520/HomePage-New.git"
  },
  "bugs": {
    "url": "https://github.com/mysterious-1314-520/HomePage-New/issues"
  },
  "homepage": "https://github.com/mysterious-1314-520/HomePage-New#readme"
}
