{
  "headers": [
    {
      "source": "/littleclicker/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ],
  "caches": [
    {
      "source": "/littleclicker/*",
      "cacheTtl": 0
    }
  ]
}
